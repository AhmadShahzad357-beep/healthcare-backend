# Copy this file to .env and fill in real values. Never commit .env itself.

# --- Required ---
GROQ_API_KEY=gsk_your_real_key_here

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_this_with_a_random_64_char_hex_string

# Comma-separated list of frontend origins allowed to call this API.
# Use your real deployed frontend URL(s) in production. "*" only for local dev.
ALLOWED_ORIGINS=http://localhost:3000

# --- Optional ---
OPENFDA_API_KEY=

# Required to verify that /whatsapp requests genuinely came from Twilio.
# Find this in your Twilio Console > Account > Auth Token.
TWILIO_AUTH_TOKEN=

# Set to true only AFTER running `python scripts/download_models.py` once.
RAG_OFFLINE_MODE=false

HOST=127.0.0.1
PORT=8000
